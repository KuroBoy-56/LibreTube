<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:text="@string/playback_speed" />

                <LinearLayout
                    android:paddingStart="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/speed_shortcuts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="20dp"
                        android:clipToPadding="false"
                        app:layoutManager="LinearLayoutManager"
                        tools:listitem="@layout/slider_label_item" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/speed"
                        style="@style/Widget.Material3.Slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stepSize="0.25"
                        android:value="1.0"
                        android:valueFrom="0.25"
                        android:valueTo="4.0"
                        app:thumbColor="?attr/colorOnSurface"
                        app:trackColorActive="?attr/colorOnSurface"
                        app:trackColorInactive="?android:attr/textColorSecondary"
                        app:trackHeight="3dp"
                        app:thumbRadius="7dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginHorizontal="10dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="23dp"
                    android:layout_marginTop="20dp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:text="@string/playback_pitch" />

                <LinearLayout
                    android:paddingHorizontal="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="23dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/semitone_decrement_button"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:padding="8dp"
                            android:src="@drawable/music_flat_symbol"
                            app:tint="?attr/colorOnSurface" />

                        <EditText
                            android:id="@+id/semitone_edit_text"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:layout_marginHorizontal="8dp"
                            android:inputType="numberDecimal|numberSigned"
                            android:background="@null"
                            android:textColor="?attr/colorOnSurface"
                            android:imeOptions="actionDone"
                            tools:text="-1.0" />

                        <ImageView
                            android:id="@+id/semitone_increment_button"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:padding="8dp"
                            android:src="@drawable/music_sharp_symbol"
                            app:tint="?attr/colorOnSurface" />

                        <ImageView
                            android:id="@+id/pitch_reset_button"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="16dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:padding="8dp"
                            android:src="@drawable/ic_restart"
                            app:tint="?android:attr/textColorSecondary" />

                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/pitch"
                        style="@style/Widget.Material3.Slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:value="0"
                        android:valueFrom="-12.0"
                        android:valueTo="12.0"
                        app:thumbColor="?attr/colorOnSurface"
                        app:trackColorActive="?attr/colorOnSurface"
                        app:trackColorInactive="?android:attr/textColorSecondary"
                        app:trackHeight="3dp"
                        app:thumbRadius="7dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginHorizontal="10dp" />

                </LinearLayout>

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/skip_silence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="17dp"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="5dp"
                    app:buttonTint="?attr/colorOnSurface"
                    android:text="@string/skip_silence" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>